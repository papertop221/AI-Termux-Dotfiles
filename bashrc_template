# --- PURE AI AGENT TERMINAL ---

# Starship Prompt (Keep it for minimal UI)
if command -v starship >/dev/null 2>&1; then
    eval "$(starship init bash)"
fi

# Core Agent Paths
AI_EXEC_FILE="$HOME/.ai_execute"
AI_CORE="$HOME/.ai_terminal.py"
LAST_CMD=""

# Capture every command for context
trap 'LAST_CMD=$BASH_COMMAND' DEBUG

# Catch-all Handler (The Brain Hook)
command_not_found_handle() {
    local status=$?
    local input="$*"
    
    # Langsung panggil Agent
    local output=$($AI_CORE "$input" "$LAST_CMD" "$status")
    
    if [[ "$output" == EXEC:* ]]; then
        local cmd="${output#EXEC: }"
        echo "$cmd" > "$AI_EXEC_FILE"
    else
        echo -e "$output"
    fi
    return 127
}

# Pure Autonomous Execution Loop
ai_agent_loop() {
    local status=$?
    if [ -f "$AI_EXEC_FILE" ]; then
        local cmd=$(cat "$AI_EXEC_FILE")
        rm -f "$AI_EXEC_FILE"
        eval "$cmd"
    fi
}

PROMPT_COMMAND="ai_agent_loop"

# Simple Welcome
clear
echo -e "\033[1;30m[ PURE AI AGENT MODE ACTIVE ]\033[0m"
