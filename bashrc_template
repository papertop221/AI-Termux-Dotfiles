# --- New Features ---
update-all() {
    echo -e "\033[1;34mUpdating packages...\033[0m"
    pkg update && pkg upgrade -y
    echo -e "\033[1;34mUpdating npm global...\033[0m"
    npm update -g
    echo -e "\033[1;34mUpdating pip packages...\033[0m"
    pip list --outdated --format=freeze | grep -v '^\-e' | cut -d = -f 1 | xargs -n1 pip install -U
    echo -e "\033[1;32mDone.\033[0m"
}

